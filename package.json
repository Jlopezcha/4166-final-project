{
  "name": "final-project-template",
  "version": "1.0.0",
  "description": "Final project of library management system for 4166 backend development class",
  "license": "ISC",
  "author": "Jerry Lopez Chaparro",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --env-file=.env --watch src/server.js",
    "start": "node src/server.js",
    "migrate:dev": "npx prisma migrate dev",
    "migrate:deploy": "npx prisma migrate deploy",
    "seed:dev": "node --env-file=.env prisma/seed.js",
    "seed:prod": "node prisma/seed.js"
  },
  "keywords": [
    "node",
    "express",
    "prisma",
    "postgres",
    "api",
    "tasks"
  ],
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "express": "^5.1.0",
    "express-validator": "^7.2.1",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.5",
    "globals": "^16.2.0",
    "prettier": "^3.6.1",
    "prisma": "^7.8.0"
  }
}
